{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.electron.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "types": ["node", "electron"],
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "rootDir": "../..",
    "outDir": "dist-electron"
  },
  "include": ["electron/**/*.ts", "src/shared/**/*.ts", "../../packages/**/*.ts"],
  "exclude": ["../../packages/**/*.test.ts"]
}
