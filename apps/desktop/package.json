{
  "name": "@yogurt/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Internal reverse-engineered prototype of Granola-style desktop UI",
  "type": "module",
  "main": "dist-electron/apps/desktop/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:cdp": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:cdp\"",
    "dev:renderer": "vite",
    "dev:electron": "concurrently -k \"npm:watch:electron\" \"npm:start:electron-dev\"",
    "dev:electron:cdp": "concurrently -k \"npm:watch:electron\" \"npm:start:electron-dev:cdp\"",
    "watch:electron": "tsc -p tsconfig.electron.json -w --preserveWatchOutput",
    "start:electron-dev": "wait-on tcp:5173 file:dist-electron/apps/desktop/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start:electron-dev:cdp": "wait-on tcp:5173 file:dist-electron/apps/desktop/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron . --remote-debugging-port=9222",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "npm run build && electron .",
    "start:cdp": "npm run build && electron . --remote-debugging-port=9222",
    "cdp:capture": "node scripts/cdp-capture-context.mjs --label ui-task",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "node scripts/visual-diff.mjs",
    "test:smoke": "npm run build && node scripts/smoke-check.mjs",
    "lint": "eslint .",
    "typecheck": "tsc -b && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "fast-xml-parser": "^5.3.5",
    "react-markdown": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.2",
    "wait-on": "^9.0.3"
  }
}
